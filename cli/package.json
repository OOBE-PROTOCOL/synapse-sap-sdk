{
  "name": "@oobe-protocol-labs/synapse-sap-cli",
  "version": "0.6.0",
  "description": "CLI toolkit for the Synapse Agent Protocol (SAP v2) on Solana",
  "license": "MIT",
  "bin": {
    "synapse-sap": "./dist/cli.js"
  },
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/cli.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "yarn clean && yarn build"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@oobe-protocol-labs/synapse-sap-sdk": "0.5.0",
    "@solana/web3.js": "^1.98.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
