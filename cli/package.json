{
  "name": "@oobe-protocol-labs/synapse-sap-cli",
  "version": "0.6.0",
  "description": "CLI toolkit for the Synapse Agent Protocol (SAP v2) on Solana — register agents, manage escrows, automate x402 payments, publish tool manifests, and more.",
  "license": "MIT",
  "author": "OOBE Protocol Labs <steve@oobeprotocol.ai>",
  "homepage": "https://github.com/OOBE-PROTOCOL/synapse-sap-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OOBE-PROTOCOL/synapse-sap-cli.git"
  },
  "bugs": {
    "url": "https://github.com/OOBE-PROTOCOL/synapse-sap-cli/issues"
  },
  "keywords": [
    "synapse",
    "sap",
    "solana",
    "agent",
    "protocol",
    "cli",
    "x402",
    "escrow",
    "oobe",
    "ai-agent",
    "web3",
    "devtools"
  ],
  "bin": {
    "synapse-sap": "./dist/cli.js"
  },
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/cli.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "echo 'No tests yet — see CONTRIBUTING.md' && exit 0",
    "prepublishOnly": "npm run clean && npm run build",
    "prepack": "npm run build",
    "version": "npm run build"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@oobe-protocol-labs/synapse-sap-sdk": "^0.6.0",
    "@solana/web3.js": "^1.98.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
